# Telegram
BOT_TOKEN=your_telegram_bot_token
ADMIN_ID=your_telegram_user_id

# AssemblyAI
ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# OpenRouter
# Comma-separated list of models — bot tries each in order if previous fails
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODELS=google/gemma-3-12b-it:free,meta-llama/llama-4-scout:free,mistralai/mistral-small-3.1-24b-instruct:free,google/gemma-3-27b-it:free

# Settings
MAX_AUDIO_DURATION=7200
MAX_FILE_SIZE=20971520
LOG_LEVEL=INFO
ASSEMBLYAI_INITIAL_BALANCE=50.0
ASSEMBLYAI_RATE_PER_HOUR=0.17
